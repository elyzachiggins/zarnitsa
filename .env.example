# Cloud backbone
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Default backbone selection: "anthropic" | "gemini" | "openrouter" | "ollama"
ZARNITSA_BACKBONE=anthropic

# Default model per backbone
ZARNITSA_ANTHROPIC_MODEL=claude-opus-4-7
ZARNITSA_GEMINI_MODEL=gemini-2.5-pro
ZARNITSA_OLLAMA_MODEL=gemma3:27b
ZARNITSA_OLLAMA_HOST=http://localhost:11434

# Corpus snapshot to load (data/corpus/snapshots/<name>)
ZARNITSA_CORPUS_SNAPSHOT=2026-05

# API server
ZARNITSA_HOST=127.0.0.1
ZARNITSA_PORT=8000

# Fidelity floor: "strict" refuses claims without corpus support;
# "permissive" allows model-extrapolation tagged outputs
ZARNITSA_FIDELITY_MODE=strict
